<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CuidarProximoCuidador" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">#F4F9FB</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="CadastroSectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:textColor">#075FA8</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CadastroInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:background">@drawable/bg_login_input</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:singleLine">true</item>
        <item name="android:textColor">#111827</item>
        <item name="android:textColorHint">#78909C</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="NavCuidadorItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">5dp</item>
        <item name="android:layout_marginHorizontal">3dp</item>
    </style>

    <style name="NavCuidadorIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:tint">#64748B</item>
    </style>

    <style name="NavCuidadorLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:textColor">#64748B</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="HomeStatBox">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">82dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/bg_soft_panel</item>
        <item name="android:elevation">4dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#0F2F3D</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ProfileMenuTitle">
        <item name="android:textColor">#334155</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ProfileMenuSubtitle">
        <item name="android:textColor">#64748B</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>
