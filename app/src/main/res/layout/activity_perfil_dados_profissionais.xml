<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_soft"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/buttonVoltarDados"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="‹  Perfil"
            android:textColor="#075FA8"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Dados profissionais"
            android:textColor="#0F172A"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Currículo visível para famílias antes de aceitarem o cuidado."
            android:textColor="#64748B"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Função principal"
            android:textColor="#0F172A"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerFuncaoProfissional"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_login_input"
            android:paddingHorizontal="12dp" />

        <EditText
            android:id="@+id/editDadosValorHora"
            style="@style/CadastroInput"
            android:layout_marginTop="10dp"
            android:hint="Valor por hora"
            android:inputType="numberDecimal"
            android:text="80" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tempo no ramo"
            android:textColor="#0F172A"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editAnoInicio"
                style="@style/CadastroInput"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:hint="Ano início"
                android:inputType="number"
                android:maxLength="4" />

            <EditText
                android:id="@+id/editAnoFim"
                style="@style/CadastroInput"
                android:layout_width="0dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:hint="Até"
                android:inputType="number"
                android:maxLength="4" />
        </LinearLayout>

        <EditText
            android:id="@+id/editDadosEspecialidades"
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_login_input"
            android:gravity="top"
            android:hint="Ex.: Alzheimer leve, mobilidade, banho assistido, rotina de medicamentos, companhia, prevenção de quedas..."
            android:inputType="textMultiLine|textCapSentences"
            android:padding="14dp"
            android:textColor="#111827"
            android:textColorHint="#78909C"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Fale sobre você"
            android:textColor="#0F172A"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editDadosSobreVoce"
            android:layout_width="match_parent"
            android:layout_height="118dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_login_input"
            android:gravity="top"
            android:hint="Conte um pouco sobre sua personalidade, sua forma de cuidar e o que considera importante no atendimento ao idoso."
            android:inputType="textMultiLine|textCapSentences"
            android:padding="14dp"
            android:textColor="#111827"
            android:textColorHint="#78909C"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/editDadosBio"
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_login_input"
            android:gravity="top"
            android:hint="Resumo profissional para aparecer no perfil público."
            android:inputType="textMultiLine|textCapSentences"
            android:padding="14dp"
            android:textColor="#111827"
            android:textColorHint="#78909C"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Dias disponíveis"
            android:textColor="#0F172A"
            android:textSize="17sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:columnCount="2">

            <CheckBox android:id="@+id/checkSegunda" android:layout_width="0dp" android:layout_height="46dp" android:layout_columnWeight="1" android:text="Segunda" android:textColor="#334155" />
            <CheckBox android:id="@+id/checkTerca" android:layout_width="0dp" android:layout_height="46dp" android:layout_columnWeight="1" android:text="Terça" android:textColor="#334155" />
            <CheckBox android:id="@+id/checkQuarta" android:layout_width="0dp" android:layout_height="46dp" android:layout_columnWeight="1" android:text="Quarta" android:textColor="#334155" />
            <CheckBox android:id="@+id/checkQuinta" android:layout_width="0dp" android:layout_height="46dp" android:layout_columnWeight="1" android:text="Quinta" android:textColor="#334155" />
            <CheckBox android:id="@+id/checkSexta" android:layout_width="0dp" android:layout_height="46dp" android:layout_columnWeight="1" android:text="Sexta" android:textColor="#334155" />
            <CheckBox android:id="@+id/checkSabado" android:layout_width="0dp" android:layout_height="46dp" android:layout_columnWeight="1" android:text="Sábado" android:textColor="#334155" />
            <CheckBox android:id="@+id/checkDomingo" android:layout_width="0dp" android:layout_height="46dp" android:layout_columnWeight="1" android:text="Domingo" android:textColor="#334155" />
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editHoraInicio"
                style="@style/CadastroInput"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:hint="De"
                android:inputType="time" />

            <EditText
                android:id="@+id/editHoraFim"
                style="@style/CadastroInput"
                android:layout_width="0dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:hint="Até"
                android:inputType="time" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Áreas que atende"
            android:textColor="#0F172A"
            android:textSize="17sp"
            android:textStyle="bold" />

        <CheckBox android:id="@+id/checkAlzheimer" android:layout_width="match_parent" android:layout_height="46dp" android:text="Alzheimer e demências leves" android:textColor="#334155" />
        <CheckBox android:id="@+id/checkMobilidade" android:layout_width="match_parent" android:layout_height="46dp" android:text="Mobilidade, banho e prevenção de quedas" android:textColor="#334155" />
        <CheckBox android:id="@+id/checkMedicamentos" android:layout_width="match_parent" android:layout_height="46dp" android:text="Lembretes e organização de medicamentos" android:textColor="#334155" />
        <CheckBox android:id="@+id/checkCompanhia" android:layout_width="match_parent" android:layout_height="46dp" android:text="Companhia, alimentação e rotina da casa" android:textColor="#334155" />

        <TextView
            android:id="@+id/textCertificados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_profile_card"
            android:elevation="2dp"
            android:padding="16dp"
            android:text="Cursos e certificados\nNenhum certificado adicionado"
            android:textColor="#334155"
            android:textSize="14sp" />

        <Button
            android:id="@+id/buttonAdicionarCertificado"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_login_button_accent"
            android:text="Adicionar curso ou certificado"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_status_good"
            android:padding="16dp"
            android:text="Famílias costumam procurar: experiência comprovada, boa comunicação, rotina clara, segurança, referências e facilidade com mobilidade."
            android:textColor="#245B47"
            android:textSize="14sp" />

        <Button
            android:id="@+id/buttonSalvarDadosProfissionais"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_login_button_primary"
            android:text="Salvar currículo"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
