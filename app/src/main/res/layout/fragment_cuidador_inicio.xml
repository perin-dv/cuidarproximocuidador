<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textInicioNome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Olá, cuidador"
            android:textColor="#0F2F3D"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Controle sua disponibilidade e acompanhe novas oportunidades."
            android:textColor="#436574"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_soft_panel"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Disponível para cuidar hoje?"
                android:textColor="#0F2F3D"
                android:textSize="19sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonDisponivel"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_login_button_primary"
                android:text="Ficar disponível"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textStatusDisponivel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_status_warn"
                android:padding="12dp"
                android:text="Você está indisponível. O GPS fica desligado até você entrar online."
                android:textColor="#7C4A03"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="132dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_soft_panel"
            android:elevation="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mapa de oportunidades"
                android:textColor="#075FA8"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:text="Quando ficar disponível, aqui entram área de atendimento, propostas próximas e rota."
                android:textColor="#436574"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Resumo"
            android:textColor="#0F2F3D"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                style="@style/HomeStatBox"
                android:text="1\nproposta" />

            <TextView
                style="@style/HomeStatBox"
                android:layout_marginHorizontal="8dp"
                android:text="0\nhoje" />

            <TextView
                style="@style/HomeStatBox"
                android:text="R$ 0\nganhos" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
