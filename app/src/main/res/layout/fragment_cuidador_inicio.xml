<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F7F9"
    android:clipToPadding="false"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_top"
            android:elevation="2dp"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="22dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textInicioNome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Bem-vinda, Kelly"
                        android:textColor="#101828"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textInicioSub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Encontre propostas perto de você"
                        android:textColor="#667085"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_home_pin"
                    android:gravity="center"
                    android:text="!"
                    android:textColor="#075FA8"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_home_search"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#075FA8"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Buscar por banho, plantão, companhia..."
                    android:textColor="#667085"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="56dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_home_pin"
                    android:gravity="center"
                    android:text="Filtro"
                    android:textColor="#075FA8"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textStatusDisponivel"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_home_pin"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:text="Maringá, PR"
                    android:textColor="#073B73"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/buttonDisponivel"
                    android:layout_width="104dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_login_button_primary"
                    android:text="Me ache"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp">

            <HorizontalScrollView
                android:id="@+id/bannerCarousel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/bannerTrack"
                    android:layout_width="wrap_content"
                    android:layout_height="150dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_home_banner"
                        android:elevation="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Vagas próximas esperando análise"
                                android:textColor="#FFFFFF"
                                android:textSize="21sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Escolha por distância, horário e tipo de cuidado."
                                android:textColor="#D7F3FF"
                                android:textSize="13sp" />

                            <TextView
                                android:layout_width="132dp"
                                android:layout_height="36dp"
                                android:layout_marginTop="12dp"
                                android:background="@drawable/bg_home_pin"
                                android:gravity="center"
                                android:text="3 disponíveis"
                                android:textColor="#073B73"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="74dp"
                            android:layout_height="74dp"
                            android:background="@drawable/bg_home_pin"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="#073B73"
                            android:textSize="30sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_home_banner"
                        android:elevation="5dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                            android:text="Currículo pronto para enviar"
                        android:textColor="#FFFFFF"
                            android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                            android:text="Famílias veem sua experiência, cidade e qualificações."
                        android:textColor="#D7F3FF"
                        android:textSize="13sp" />

                    <TextView
                            android:layout_width="146dp"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_home_pin"
                        android:gravity="center"
                            android:text="Perfil visível"
                        android:textColor="#073B73"
                        android:textStyle="bold" />
                </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_home_banner"
                        android:elevation="5dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Receba convites diretos"
                            android:textColor="#FFFFFF"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Quando o cliente escolher você, aceite ou recuse na aba Propostas."
                            android:textColor="#D7F3FF"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="156dp"
                            android:layout_height="36dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_home_pin"
                            android:gravity="center"
                            android:text="Notificação ativa"
                            android:textColor="#073B73"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/bannerDots"
                android:layout_width="match_parent"
                android:layout_height="22dp"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/dotBanner1"
                    android:layout_width="22dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_banner_dot_active" />

                <TextView
                    android:id="@+id/dotBanner2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="7dp"
                    android:background="@drawable/bg_banner_dot_inactive" />

                <TextView
                    android:id="@+id/dotBanner3"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="7dp"
                    android:background="@drawable/bg_banner_dot_inactive" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Tipos de cuidado"
                android:textColor="#101828"
                android:textSize="19sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_home_category"
                    android:gravity="center"
                    android:text="Banho\nassistido"
                    android:textColor="#0F2F3D"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_home_category"
                    android:gravity="center"
                    android:text="Plantão\nnoturno"
                    android:textColor="#0F2F3D"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_home_category"
                    android:gravity="center"
                    android:text="Companhia\ndiária"
                    android:textColor="#0F2F3D"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardPropostaHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_proposal_card"
                android:elevation="5dp"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textTagPropostaHome"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_chip_soft"
                        android:gravity="center"
                        android:paddingHorizontal="12dp"
                        android:text="Nova vaga"
                        android:textColor="#075FA8"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_home_pin"
                        android:gravity="center"
                        android:paddingHorizontal="10dp"
                        android:text="2,4 km"
                        android:textColor="#075FA8"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imageIdosoHome"
                        android:layout_width="62dp"
                        android:layout_height="62dp"
                        android:background="@drawable/bg_avatar_elder"
                        android:padding="12dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_profile_face" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="13dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textIdosoHome"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Irene, 80 anos"
                            android:textColor="#101828"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textResumoPropostaHome"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Apoio preventivo • Maringá, PR"
                            android:textColor="#667085"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_home_offer_highlight"
                    android:orientation="horizontal"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/textHomeValor"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Precisa\ncompanhia"
                        android:textColor="#0F2F3D"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textHomeTempo"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="4h"
                        android:textColor="#0F2F3D"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textHomeDistancia"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Maringá\nPR"
                        android:textColor="#0F2F3D"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textMotivoPropostaHome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Veja os detalhes e envie seu currículo do aplicativo se fizer sentido para você."
                    android:textColor="#475467"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/buttonVerPropostaHome"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_login_button_primary"
                    android:text="Ver proposta"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_home_offer_highlight"
                android:orientation="horizontal"
                android:padding="14dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Plantão noturno • 6h • Zona 7"
                    android:textColor="#101828"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_home_pin"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:text="Ver"
                    android:textColor="#075FA8"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
