<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_soft"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="16dp"
        android:paddingEnd="14dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_card"
            android:elevation="5dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <FrameLayout
                android:id="@+id/buttonAlterarFotoPerfil"
                android:layout_width="92dp"
                android:layout_height="92dp">

                <com.mesawa.cuidarproximocuidador.ui.perfil.CircleImageView
                    android:id="@+id/imageFotoPerfil"
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_avatar_circle"
                    android:contentDescription="Foto de perfil"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_account_box" />

                <TextView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_icon_blue"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#075FA8"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:id="@+id/textPerfilNome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Kelly"
                android:textColor="#0F172A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textPerfilEspecialidade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="Cuidadora de idosos • Maringá"
                android:textColor="#64748B"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/textPerfilResumo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="5.0 estrelas • 0 atendimentos"
                android:textColor="#D99A00"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textPerfilStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_status_good"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="● Perfil ativo e verificado"
                android:textColor="#138A57"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowDadosProfissionais"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_menu_row"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_blue"
                android:padding="8dp"
                android:src="@drawable/ic_profile_work" />

            <TextView
                style="@style/ProfileMenuTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Dados profissionais" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="#64748B"
                android:textSize="18sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowAvaliacoes"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_menu_row"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_yellow"
                android:padding="8dp"
                android:src="@drawable/ic_profile_star" />

            <TextView
                style="@style/ProfileMenuTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Avaliações" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="#64748B"
                android:textSize="18sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowCarteira"
            android:layout_width="match_parent"
            android:layout_height="66dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_menu_row"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_green"
                android:padding="8dp"
                android:src="@drawable/ic_profile_wallet" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/ProfileMenuTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Carteira" />

                <TextView
                    style="@style/ProfileMenuSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Em breve: saldo, repasses e saques" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowSuporte"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_menu_row"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_pink"
                android:padding="8dp"
                android:src="@drawable/ic_profile_support" />

            <TextView
                style="@style/ProfileMenuTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Suporte e SAC" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="#64748B"
                android:textSize="18sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowConfiguracoes"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_menu_row"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_blue"
                android:padding="8dp"
                android:src="@drawable/ic_profile_settings" />

            <TextView
                style="@style/ProfileMenuTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Configurações" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="#64748B"
                android:textSize="18sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowReconhecimentoFacial"
            android:layout_width="match_parent"
            android:layout_height="66dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_menu_row"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_green"
                android:padding="8dp"
                android:src="@drawable/ic_profile_face" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/ProfileMenuTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reconhecimento facial" />

                <TextView
                    style="@style/ProfileMenuSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Confirme identidade com selfie e documento" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="#64748B"
                android:textSize="18sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowPremium"
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_premium_row"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_purple"
                android:padding="8dp"
                android:src="@drawable/ic_profile_crown" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Premium"
                    android:textColor="#1D2F7A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Em breve: destaque, relatórios e IA de atendimento"
                    android:textColor="#64748B"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="#64748B"
                android:textSize="18sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowSairConta"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_menu_row"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_pink"
                android:padding="8dp"
                android:src="@drawable/ic_profile_logout" />

            <TextView
                style="@style/ProfileMenuTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Sair da conta"
                android:textColor="#D92D4B" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="#D92D4B"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
