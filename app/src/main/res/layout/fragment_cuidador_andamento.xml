<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Andamento"
        android:textColor="#0F2F3D"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_soft_panel"
        android:elevation="4dp"
        android:padding="18dp"
        android:text="Quando aceitar uma proposta, acompanhe rota, chegada, chat e início/fim do cuidado por aqui."
        android:textColor="#436574"
        android:textSize="15sp" />

    <Button
        android:id="@+id/buttonAbrirAndamentoTeste"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_login_button_primary"
        android:text="Abrir andamento de teste"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />
</LinearLayout>
