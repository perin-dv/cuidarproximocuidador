<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="28dp"
        android:paddingEnd="22dp"
        android:paddingBottom="30dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cadastro do cuidador"
            android:textColor="#075FA8"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="18dp"
            android:text="Informe seus dados para análise profissional, validação de segurança e liberação para atendimentos."
            android:textColor="#436574"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_login_card"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/textCadastroMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_login_message"
                android:padding="12dp"
                android:textColor="#9A3412"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                style="@style/CadastroSectionTitle"
                android:text="Dados pessoais" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_login_message"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <ImageView
                    android:id="@+id/imageFotoPerfilCadastro"
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:background="@drawable/bg_soft_panel"
                    android:contentDescription="Foto de perfil"
                    android:padding="14dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_account_box" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Foto profissional"
                        android:textColor="#0F2F3D"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Use uma foto clara do rosto. Ela aparecerá para as famílias após aprovação."
                        android:textColor="#436574"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/buttonEscolherFotoPerfil"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_login_button_accent"
                        android:minWidth="0dp"
                        android:paddingHorizontal="16dp"
                        android:text="Escolher foto"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <EditText
                android:id="@+id/editNomeCompleto"
                style="@style/CadastroInput"
                android:hint="Nome completo"
                android:inputType="textPersonName" />

            <EditText
                android:id="@+id/editCpf"
                style="@style/CadastroInput"
                android:hint="CPF"
                android:inputType="number" />

            <EditText
                android:id="@+id/editNascimento"
                style="@style/CadastroInput"
                android:hint="Data de nascimento"
                android:inputType="date" />

            <EditText
                android:id="@+id/editTelefone"
                style="@style/CadastroInput"
                android:hint="Telefone / WhatsApp"
                android:inputType="phone" />

            <EditText
                android:id="@+id/editEmailCadastro"
                style="@style/CadastroInput"
                android:hint="Email"
                android:inputType="textEmailAddress" />

            <EditText
                android:id="@+id/editSenhaCadastro"
                style="@style/CadastroInput"
                android:hint="Senha de acesso"
                android:inputType="textPassword" />

            <TextView
                style="@style/CadastroSectionTitle"
                android:layout_marginTop="14dp"
                android:text="Endereço e atendimento" />

            <EditText
                android:id="@+id/editCidade"
                style="@style/CadastroInput"
                android:hint="Cidade de atendimento"
                android:inputType="textCapWords" />

            <EditText
                android:id="@+id/editUf"
                style="@style/CadastroInput"
                android:hint="UF"
                android:inputType="textCapCharacters"
                android:maxLength="2" />

            <EditText
                android:id="@+id/editRaio"
                style="@style/CadastroInput"
                android:hint="Raio de atendimento em km"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editValorHora"
                style="@style/CadastroInput"
                android:hint="Valor por hora"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/editDisponibilidade"
                style="@style/CadastroInput"
                android:hint="Disponibilidade"
                android:inputType="textCapSentences" />

            <TextView
                style="@style/CadastroSectionTitle"
                android:layout_marginTop="14dp"
                android:text="Qualificação e experiência" />

            <EditText
                android:id="@+id/editEspecialidade"
                style="@style/CadastroInput"
                android:hint="Especialidade"
                android:inputType="textCapSentences" />

            <EditText
                android:id="@+id/editCurso"
                style="@style/CadastroInput"
                android:hint="Curso/qualificação principal"
                android:inputType="textCapSentences" />

            <EditText
                android:id="@+id/editInstituicao"
                style="@style/CadastroInput"
                android:hint="Instituição do curso"
                android:inputType="textCapWords" />

            <EditText
                android:id="@+id/editExperiencia"
                style="@style/CadastroInput"
                android:hint="Tempo de experiência"
                android:inputType="textCapSentences" />

            <EditText
                android:id="@+id/editBio"
                android:layout_width="match_parent"
                android:layout_height="104dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_login_input"
                android:gravity="top"
                android:hint="Resumo profissional"
                android:inputType="textMultiLine|textCapSentences"
                android:padding="14dp"
                android:textColor="#111827"
                android:textColorHint="#78909C"
                android:textSize="15sp" />

            <CheckBox
                android:id="@+id/checkMedicacao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tenho experiência com rotina de medicamentos"
                android:textColor="#374151" />

            <CheckBox
                android:id="@+id/checkMobilidade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tenho experiência com mobilidade, banho e prevenção de quedas"
                android:textColor="#374151" />

            <CheckBox
                android:id="@+id/checkAlzheimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tenho experiência com Alzheimer/demências"
                android:textColor="#374151" />

            <TextView
                style="@style/CadastroSectionTitle"
                android:layout_marginTop="14dp"
                android:text="Segurança e referências" />

            <EditText
                android:id="@+id/editAntecedentes"
                style="@style/CadastroInput"
                android:hint="Protocolo ou data da certidão de antecedentes"
                android:inputType="textCapCharacters" />

            <EditText
                android:id="@+id/editReferenciaNome"
                style="@style/CadastroInput"
                android:hint="Nome de uma referência profissional"
                android:inputType="textPersonName" />

            <EditText
                android:id="@+id/editReferenciaTelefone"
                style="@style/CadastroInput"
                android:hint="Telefone da referência"
                android:inputType="phone" />

            <CheckBox
                android:id="@+id/checkVerificacao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Autorizo a verificação dos dados, documentos, referências e antecedentes criminais."
                android:textColor="#374151" />

            <ProgressBar
                android:id="@+id/progressCadastro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/buttonEnviarCadastro"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_login_button_primary"
                android:text="Enviar cadastro para análise"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
