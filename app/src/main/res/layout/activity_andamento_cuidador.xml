<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_soft"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="118dp"
            android:background="@drawable/bg_metric_blue"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Acompanhamento"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Contrato CTR-TESTE-KELLY • cuidadora a caminho"
                android:textColor="#DDF4FF"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_profile_card"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:background="@drawable/bg_avatar_circle"
                android:gravity="center"
                android:text="I"
                android:textColor="#0F172A"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Irene • 80 anos"
                    android:textColor="#0F172A"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="4h de cuidado • Rua das Flores, 123"
                    android:textColor="#64748B"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_status_good"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:text="● A caminho do local"
                    android:textColor="#138A57"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/mapPreview"
            android:layout_width="match_parent"
            android:layout_height="292dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_map_offline"
            android:elevation="5dp">

            <TextView
                android:layout_width="118dp"
                android:layout_height="62dp"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"
                android:background="@drawable/bg_login_button_accent"
                android:gravity="center"
                android:text="12 min\n5,2 km"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="150dp"
                android:layout_height="54dp"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:background="@drawable/bg_profile_card"
                android:gravity="center"
                android:padding="8dp"
                android:text="Destino\nRua das Flores, 123"
                android:textColor="#334155"
                android:textSize="11sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:layout_gravity="bottom"
                android:background="#CC123A49"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:text="Origem: sua localização atual\nDestino: endereço do idoso\nToque para abrir no Google Maps ou ampliar GPS"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/panelMapaAmpliado"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_metric_dark"
            android:elevation="5dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="18dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="GPS ampliado"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Modo offline visual ativo. Ao integrar localização real, esta área recebe rota, pontos e atualização ao vivo."
                android:textColor="#DDF4FF"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonIniciarCuidado"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:background="@drawable/bg_login_button_primary"
                android:text="Iniciar cuidado"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonAvisarChegada"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_login_button_accent"
                android:text="Avisar chegada"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_profile_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chat do cuidado"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textChatHistorico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_status_warn"
                android:padding="12dp"
                android:text="Família: Olá Kelly, pode avisar quando estiver chegando?\n\nKelly: Claro, estou a caminho e aviso ao chegar."
                android:textColor="#263A46"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_login_input"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp">

                <EditText
                    android:id="@+id/editMensagemChat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Mensagem"
                    android:singleLine="true"
                    android:textColor="#111827"
                    android:textColorHint="#78909C" />

                <Button
                    android:id="@+id/buttonEnviarMensagem"
                    android:layout_width="82dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_login_button_primary"
                    android:text="Enviar"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
