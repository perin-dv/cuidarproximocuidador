<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".CuidarProximoCuidadorApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CuidarProximoCuidador">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.CuidarProximoCuidador">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".Login.LoginActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.CuidarProximoCuidador" />

        <activity
            android:name=".Cadastro.CadastroCuidadorActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.CuidarProximoCuidador" />

        <activity
            android:name=".ui.HomeCuidadorActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.CuidarProximoCuidador" />

        <activity
            android:name=".ui.propostas.PropostaDetalheActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.CuidarProximoCuidador" />

        <activity
            android:name=".ui.andamento.AndamentoCuidadorActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.CuidarProximoCuidador" />

        <activity
            android:name=".ui.perfil.PhotoAdjustActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.CuidarProximoCuidador" />

        <activity
            android:name=".ui.perfil.dados.DadosProfissionaisActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.CuidarProximoCuidador" />

        <activity
            android:name=".ui.perfil.avaliacoes.AvaliacoesActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.CuidarProximoCuidador" />

        <activity
            android:name=".ui.perfil.suporte.SuporteSacActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.CuidarProximoCuidador" />

        <activity
            android:name=".ui.perfil.configuracoes.ConfiguracoesActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.CuidarProximoCuidador" />

        <activity
            android:name=".ui.perfil.reconhecimento.ReconhecimentoFacialActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.CuidarProximoCuidador" />

    </application>

</manifest>
